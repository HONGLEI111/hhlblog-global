---
import type { GetStaticPaths } from "astro";
import Pagination from "../../components/controls/Pagination.astro";
import BlogPage from "../../components/blog/BlogPage.astro";
import { PAGE_SIZE } from "../../constants/constants";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../../utils/content-utils";
import TranslateTitles from "../../components/controls/TranslateTitles.svelte";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogBlog = await getSortedPosts();
	return paginate(allBlogBlog, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const len = page.data.length;
export const prerender = true;
---

<MainGridLayout sidebarCollection="posts">
    <BlogPage page={page}></BlogPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
  <TranslateTitles client:load />
</MainGridLayout>
