---
import ArchivePanel from "@components/controls/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const sortedBlogList = await getSortedPostsList();
const currentLang = Astro.locals?.lang;
---

<MainGridLayout title={i18n(I18nKey.archive, currentLang)} sidebarCollection="posts">
    <ArchivePanel sortedPosts={sortedBlogList} collection="posts" client:only="svelte"></ArchivePanel>
</MainGridLayout>
