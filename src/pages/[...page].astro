---
import BlogLatestPosts from "~/components/landing/BlogLatestPosts.astro";
import CallToAction from "~/components/landing/CallToAction.astro";
import FeatureGrid from "~/components/landing/FeatureGrid.astro";
import HeroSection from "~/components/landing/HeroSection.astro";
import StatsPanel from "~/components/landing/StatsPanel.astro";
import TechIcons from "~/components/landing/TechIcons.astro";
import Pagination from "../components/controls/Pagination.astro";
import PostPage from "../components/layout/PostPage.astro";
import { PAGE_SIZE } from "../constants/constants";
import HomeLayout from "../layouts/HomeLayout.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";
import { loadLandingContent } from "../utils/translated-content";

export const prerender = false;

const allBlogPosts = await getSortedPosts(Astro.locals?.lang);
const totalPosts = allBlogPosts.length;
const totalPages = Math.max(Math.ceil(totalPosts / PAGE_SIZE), 1);

const currentPage = Astro.params.page ? Number(Astro.params.page) : 1;

const start = (currentPage - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const pageData = allBlogPosts.slice(start, end);

const baseUrl = Astro.url.origin + "/";

const page = {
	data: pageData,
	start,
	end: Math.min(end, totalPosts),
	total: totalPosts,
	size: PAGE_SIZE,
	currentPage,
	lastPage: totalPages,
	url: {
		first: baseUrl,
		last: totalPages > 1 ? `${baseUrl}${totalPages}/` : baseUrl,
		current: currentPage === 1 ? baseUrl : `${baseUrl}${currentPage}/`,
		prev:
			currentPage > 1
				? currentPage === 2
					? baseUrl
					: `${baseUrl}${currentPage - 1}/`
				: undefined,
		next:
			currentPage < totalPages ? `${baseUrl}${currentPage + 1}/` : undefined,
	},
};

const len = page.data.length;
const isHomePage = currentPage === 1;

const landing = await loadLandingContent(Astro.locals?.lang);
---

{
  isHomePage ? (
    <HomeLayout>
      <HeroSection
        greeting={landing.hero.greeting}
        title={landing.hero.title}
        description={landing.hero.description}
        github="https://github.com/HONGLEI111/hhlblog-global"
      />

      <FeatureGrid features={landing.features} />

      <StatsPanel stats={landing.stats} labels={landing.statsLabels} />

      <TechIcons items={landing.techStack} />

      <CallToAction
        title={landing.cta.title}
        description={landing.cta.description}
        email={landing.cta.email}
      />

      <BlogLatestPosts
        title={landing.latestPosts.title}
        information={landing.latestPosts.information}
      />
    </HomeLayout>
  ) : (
    <MainGridLayout>
      <PostPage page={page}></PostPage>
      <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
    </MainGridLayout>
  )
}
