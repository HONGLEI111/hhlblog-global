---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { friendsConfig } from "../../config";

const tools = [
	{
		title: "画廊",
		desc: "浏览精选图片集",
		href: "https://img.hehonglei.cn",
		icon: "material-symbols:photo-library-rounded",
	},
	{
		title: "文件",
		desc: "下载公开文件资源",
		href: "https://files.hehonglei.cn",
		icon: "material-symbols:folder-open-rounded",
	},
	{
		title: "封面",
		desc: "在线生成文章封面图",
		href: "https://img.hehonglei.cn",
		icon: "material-symbols:image-rounded",
	},
	{
		title: "Excalidraw",
		desc: "在线手绘风格白板绘图工具",
		href: "https://excalidraw.com/",
		icon: "material-symbols:draw-rounded",
	},
	{
		title: "TableConvert",
		desc: "在线表格格式互转工具",
		href: "https://tableconvert.com/zh-cn/",
		icon: "material-symbols:table-rounded",
	},
	{
		title: "iLovePDF",
		desc: "PDF 合并、压缩、转换等在线工具",
		href: "https://www.ilovepdf.com/zh-cn",
		icon: "material-symbols:picture-as-pdf-rounded",
	},
	{
		title: "UUTool",
		desc: "在线多功能工具集合平台",
		href: "https://uutool.cn/",
		icon: "material-symbols:construction-rounded",
	},
];
---

<MainGridLayout title="工具">
	<div class="card-base p-6 md:p-8">
		<div class="flex items-center gap-2 mb-6">
			<Icon name="material-symbols:build-circle-rounded" class="text-[var(--primary)] w-7 h-7" />
			<h1 class="text-2xl font-bold text-75">工具</h1>
		</div>
		<p class="text-sm text-50 mb-8 leading-relaxed">
			本站提供的实用工具入口，点击卡片即可跳转使用。
		</p>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
			{tools.map((t) => (
				<a
					href={t.href}
					target="_blank"
					rel="noopener noreferrer"
					class="group block rounded-xl border border-[var(--line-color)] bg-transparent p-5 hover:bg-[var(--btn-regular-bg)] hover:border-[var(--primary)] transition-all"
				>
					<div class="flex items-center justify-between mb-2">
						<div class="flex items-center gap-3">
							<Icon name={t.icon} class="w-6 h-6 text-[var(--primary)] group-hover:scale-110 transition-transform" />
							<span class="text-lg font-bold text-75">{t.title}</span>
						</div>
						<Icon name="material-symbols:open-in-new-rounded" class="w-4 h-4 text-40 group-hover:text-[var(--primary)] transition-colors shrink-0" />
					</div>
					<p class="text-sm text-50">{t.desc}</p>
				</a>
			))}
		</div>

		{friendsConfig.friends.length > 0 && (
			<>
				<!-- Divider -->
				<div class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed"></div>

				<!-- Friends Section -->
				<div class="flex items-center gap-2 mb-6">
					<Icon name="material-symbols:bookmark-rounded" class="text-[var(--primary)] w-7 h-7" />
					<h2 class="text-2xl font-bold text-75">推荐阅读</h2>
				</div>
				<p class="text-sm text-50 mb-8 leading-relaxed">
					在我成长路上收获良多的网站，欢迎<a href="mailto:contact@hehonglei.com" class="text-[var(--primary)] hover:underline">交换链接</a>。
				</p>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
					{friendsConfig.friends.map((f) => (
						<a
							href={f.url}
							target="_blank"
							rel="noopener noreferrer"
							class="group flex items-start gap-4 rounded-xl border border-[var(--line-color)] bg-transparent p-5 hover:bg-[var(--btn-regular-bg)] hover:border-[var(--primary)] transition-all"
						>
							{f.avatar && (
								<img
									src={f.avatar}
									alt={`${f.name} 头像`}
									class="w-10 h-10 rounded-full object-cover shrink-0 ring-2 ring-[var(--line-color)] group-hover:ring-[var(--primary)] transition-all"
									loading="lazy"
								/>
							)}
							<div class="flex-1 min-w-0">
								<div class="flex items-center justify-between mb-1">
									<span class="text-lg font-bold text-75 group-hover:text-[var(--primary)] transition-colors truncate">{f.name}</span>
									<Icon name="material-symbols:open-in-new-rounded" class="w-4 h-4 text-40 group-hover:text-[var(--primary)] transition-colors shrink-0 ml-2" />
								</div>
								<p class="text-sm text-50 leading-relaxed">{f.description}</p>
							</div>
						</a>
					))}
				</div>
			</>
		)}
	</div>
</MainGridLayout>
