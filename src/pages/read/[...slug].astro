---
import path from "node:path";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import { render } from "astro:content";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedRead } from "@utils/content-utils";
import { getTranslatedBodyHtml, loadPostMetadata } from "@utils/translated-content";
import { getDir, getReadUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/read/PostMeta.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

const slug = Astro.params.slug;

const allEntries = await getSortedRead();
const entry = allEntries.find((e) => e.id.replace(/\.mdx?$/, "") === slug);

if (!entry) {
	return new Response("Not found", { status: 404 });
}
const currentLang = Astro.locals?.lang;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);

const words = remarkPluginFrontmatter.words;
const minutes = remarkPluginFrontmatter.minutes;

// Apply translated metadata
const readSlug = entry.id.replace(/\.mdx?$/, "");
let meta = null;
if (currentLang && currentLang !== "zh_CN" && currentLang !== "zh_cn") {
	meta = await loadPostMetadata(currentLang, "read", readSlug);
	if (meta) {
		if (meta.title) entry.data.title = meta.title;
		if (meta.description) entry.data.description = meta.description;
		if (meta.tags) entry.data.tags = meta.tags;
		if (meta.category) entry.data.category = meta.category;
	}
}
const translatedHeadings = meta?.toc?.length ? meta.toc : headings;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
export const prerender = false;

const translatedHtml =
	currentLang && currentLang !== "zh_CN" && currentLang !== "zh_cn"
		? await getTranslatedBodyHtml(currentLang, "read", entry.id.replace(/\.mdx?$/, ""))
		: null;
---

<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={translatedHeadings} sidebarCollection="read">
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
    <div id="post-container" class:list={["card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full", {}]}>

      <!-- word count and reading time -->
      <div class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation">
        <div class="flex flex-row items-center">
          <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
            <Icon name="material-symbols:notes-rounded"></Icon>
          </div>
          <div class="text-sm">{words} {" " + i18n(I18nKey.wordsCount, currentLang)}</div>
        </div>
        <div class="flex flex-row items-center">
          <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
            <Icon name="material-symbols:schedule-outline-rounded"></Icon>
          </div>
          <div class="text-sm">
            {minutes} {" " + i18n(minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount, currentLang)}
          </div>
        </div>
      </div>

      <!-- title -->
      <div class="relative onload-animation">
        <div
          data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
          class="transition w-full block font-bold mb-3
          text-3xl md:text-[2.25rem]/[2.75rem]
          text-black/90 dark:text-white/90
          md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
          before:absolute before:top-[0.75rem] before:left-[-1.125rem]
        ">
          {entry.data.title}
        </div>
      </div>

      <!-- metadata -->
      <div class="onload-animation">
        <PostMetadata
          class="mb-5"
          published={entry.data.published}
          updated={entry.data.updated}
          tags={entry.data.tags}
          category={entry.data.category}
          author={entry.data.author}
        ></PostMetadata>
        {!entry.data.image && !(entry.data.cover || entry.data.bookTitle || entry.data.author) && <div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5"></div>}
      </div>

      <!-- book info section -->
      {(entry.data.cover || entry.data.bookTitle || entry.data.author) && (
        <div class="flex flex-col md:flex-row gap-5 mb-8 onload-animation">
          {entry.data.cover && (
            <div class="flex-shrink-0 w-32 md:w-40 aspect-[3/4] rounded-lg overflow-hidden">
              <ImageWrapper
                src={entry.data.cover}
                basePath={path.join("content/read/", getDir(entry.id))}
                alt={entry.data.bookTitle || entry.data.title}
                class="w-full h-full object-cover"
                sizes="(min-width: 768px) 160px, 128px"
                widths={[128, 160, 256, 320]}
                quality={75}
              />
            </div>
          )}
          <div class="flex flex-col justify-center gap-2">
            {entry.data.bookTitle && (
              <h2 class="text-xl md:text-2xl font-bold text-90">{entry.data.bookTitle}</h2>
            )}
            {entry.data.author && (
              <div class="text-base text-75">{entry.data.author}</div>
            )}
            {entry.data.rating && (
              <div class="flex gap-0.5 text-[var(--primary)]">
                {Array.from({ length: 5 }, (_, i) => (
                  <Icon
                    name={i < entry.data.rating
                      ? "material-symbols:star-rounded"
                      : "material-symbols:star-outline-rounded"}
                    class="text-xl"
                  />
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      <!-- cover image -->
      {entry.data.image &&
        <ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content/read/", getDir(entry.id))}
                      class="mb-8 rounded-xl banner-container onload-animation"
                      sizes="(min-width: 1200px) 864px, (min-width: 768px) calc(100vw - 8rem), calc(100vw - 3rem)"
                      widths={[480, 640, 768, 960, 1200]}
                      quality={70}/>
      }

      <Markdown class="mb-6 markdown-content onload-animation">
        {translatedHtml ? <Fragment set:html={translatedHtml} /> : <Content />}
      </Markdown>

      {licenseConfig.enable && <License title={entry.data.title} slug={entry.id} pubDate={entry.data.published} class="mb-6 rounded-xl license-container onload-animation"></License>}

    </div>
  </div>

  <!-- prev/next navigation -->
  <div class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full">
    {entry.data.nextSlug ? (
      <a href={getReadUrlBySlug(entry.data.nextSlug)} aria-label={entry.data.nextTitle}
         class="w-full font-bold overflow-hidden active:scale-95">
        <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4" >
          <Icon name="material-symbols:chevron-left-rounded" class="text-[2rem] text-[var(--primary)]" />
          <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
            {entry.data.nextTitle}
          </div>
        </div>
      </a>
    ) : (
      <div class="w-full" aria-hidden="true"></div>
    )}

    {entry.data.prevSlug ? (
      <a href={getReadUrlBySlug(entry.data.prevSlug)} aria-label={entry.data.prevTitle}
         class="w-full font-bold overflow-hidden active:scale-95">
        <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
          <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
            {entry.data.prevTitle}
          </div>
          <Icon name="material-symbols:chevron-right-rounded" class="text-[2rem] text-[var(--primary)]" />
        </div>
      </a>
    ) : (
      <div class="w-full" aria-hidden="true"></div>
    )}
  </div>

</MainGridLayout>

<style>
  .markdown-content > p:first-of-type {
    font-style: italic;
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    font-size: 1.125rem;
    color: var(--aw-color-text-muted);
  }
</style>
