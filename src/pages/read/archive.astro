---
import ArchivePanel from "@components/controls/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedReadList } from "@utils/content-utils";

const sortedReadList = await getSortedReadList(Astro.locals?.lang);
const currentLang = Astro.locals?.lang;
---

<MainGridLayout title={i18n(I18nKey.archive, currentLang)} sidebarCollection="read">
    <ArchivePanel sortedPosts={sortedReadList} collection="read" client:only="svelte"></ArchivePanel>
</MainGridLayout>
