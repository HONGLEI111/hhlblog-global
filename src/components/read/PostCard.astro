---
import { render, type CollectionEntry } from "astro:content";
import path from "node:path";
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { getDir } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const currentLang = Astro.locals?.lang;

interface Props {
    class?: string;
    entry: CollectionEntry<"read">;
    title: string;
    url: string;
    published: Date;
    updated?: Date;
    tags: string[];
    category: string | null;
    image: string;
    description: string;
    draft: boolean;
    style: string;
    author?: string;
    bookTitle?: string;
    rating?: number;
    cover?: string;
}
const {
    entry,
    title,
    url,
    published,
    style,
    author,
    bookTitle,
    rating,
    cover,
    image,
} = Astro.props;
const className = Astro.props.class;

const displayCover = cover || image;
const hasCover = displayCover !== undefined && displayCover !== null && displayCover !== "";
const displayBookTitle = bookTitle || title;
const showExcerptTitle = bookTitle && bookTitle !== title;

const { remarkPluginFrontmatter } = await render(entry);
const minutes = remarkPluginFrontmatter.minutes;
---

<div class:list={["card-base flex flex-col w-full rounded-[var(--radius-large)] overflow-hidden", className]} style={style}>
    <!-- Cover image -->
    <a href={url} aria-label={displayBookTitle}
       class:list={["group relative block w-full overflow-hidden",
           hasCover ? "aspect-[3/4]" : "aspect-[3/4] bg-gradient-to-br from-[var(--card-bg)] to-[var(--primary)]/10"
       ]} >
        {hasCover ? (
            <>
                <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
                <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center">
                    <Icon name="material-symbols:chevron-right-rounded"
                          class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl">
                    </Icon>
                </div>
                <ImageWrapper src={displayCover} basePath={path.join("content/read/", getDir(entry.id))} alt={displayBookTitle}
                          class="w-full h-full object-cover transition duration-300 group-hover:scale-105"
                          sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                          widths={[320, 480, 640, 768]}
                          quality={70}>
                </ImageWrapper>
            </>
        ) : (
            <div class="w-full h-full flex items-center justify-center">
                <Icon name="material-symbols:book-2-rounded" class="text-5xl text-30"></Icon>
            </div>
        )}
    </a>

    <!-- Info block -->
    <div class="p-4 flex flex-col gap-1 flex-1">
        <!-- Book title -->
        <a href={url} class="transition font-bold text-base text-90 line-clamp-1 hover:text-[var(--primary)] dark:hover:text-[var(--primary)]">
            {displayBookTitle}
        </a>

        <!-- Author -->
        {author && (
            <div class="text-sm text-50 line-clamp-1">{author}</div>
        )}

        <!-- Excerpt title (only when bookTitle differs from title) -->
        {showExcerptTitle && (
            <div class="text-xs text-30 line-clamp-1">{title}</div>
        )}

        <!-- Meta row: date + reading time + rating -->
        <div class="flex items-center gap-2 text-xs text-30 mt-auto pt-2">
            <span>{formatDateToYYYYMMDD(published)}</span>
            <span>·</span>
            <span>{minutes} {i18n(minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount, currentLang)}</span>
            {rating && (
                <>
                    <span>·</span>
                    <span class="flex items-center gap-0.5 text-[var(--primary)]">
                        <Icon name="material-symbols:star-rounded" class="text-sm" />
                        <span class="text-50">{rating}</span>
                    </span>
                </>
            )}
        </div>
    </div>
</div>
<div class="transition border-t-[1px] border-dashed mx-6 border-black/10 dark:border-white/[0.15] last:border-t-0 md:hidden"></div>
