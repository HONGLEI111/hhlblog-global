---
import type { CollectionEntry } from "astro:content";
import path from "node:path";
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getDir } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";
import PostMetadata from "./PostMeta.astro";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string | null;
	image: string;
	description: string;
	draft: boolean;
	style: string;
}
const {
	entry,
	title,
	url,
	published,
	updated,
	tags,
	category,
	image,
	description,
	style,
} = Astro.props;
const className = Astro.props.class;

const hasCover = image !== undefined && image !== null && image !== "";

const { remarkPluginFrontmatter } = await entry.render();
const currentLang = Astro.locals?.lang;
---

<article
  class:list={[
    "card-base card-shadow group overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg",
    className
  ]}
  style={style}
>
  <!-- Cover Image -->
  {hasCover && (
    <a href={url} aria-label={title} class="block overflow-hidden">
      <div class="relative overflow-hidden">
        <ImageWrapper
          src={image}
          basePath={path.join("content/posts/", getDir(entry.id))}
          alt="Cover Image of the Post"
          class="w-full h-44 sm:h-52 object-cover transition-transform duration-500 group-hover:scale-105"
          sizes="(min-width: 768px) 50vw, 100vw"
          widths={[480, 640, 768, 1024]}
          quality={75}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      </div>
    </a>
  )}

  <!-- Content -->
  <div class="px-4 sm:px-6 md:px-8 pt-4 pb-5 sm:pt-5 sm:pb-6 md:pt-6 md:pb-7">
    <!-- Title -->
    <a
      href={url}
      class="block group/title mb-3"
    >
      <h2
        class="text-lg sm:text-xl md:text-2xl font-bold leading-snug text-90 transition-colors duration-200 group-hover/title:text-[var(--primary)] dark:group-hover/title:text-[var(--primary)]"
      >
        {title}
      </h2>
    </a>

    <!-- Metadata -->
    <PostMetadata
      published={published}
      updated={updated}
      tags={tags}
      category={category}
      hideTagsForMobile={true}
      hideUpdateDate={true}
      class="mb-3"
    />

    <!-- Description -->
    <div class:list={["text-75 leading-relaxed mb-3 sm:mb-4", {"line-clamp-2": !description}]}>
      {description || remarkPluginFrontmatter.excerpt}
    </div>

    <!-- Word count and read time -->
    <div class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm text-50">
      <div class="flex items-center gap-1 sm:gap-1.5">
        <Icon name="material-symbols:text-snippet-outline-rounded" class="text-base sm:text-lg opacity-60" />
        <span>{remarkPluginFrontmatter.words} {" " + i18n(remarkPluginFrontmatter.words === 1 ? I18nKey.wordCount : I18nKey.wordsCount, currentLang)}</span>
      </div>
      <div class="text-black/15 dark:text-white/20">|</div>
      <div class="flex items-center gap-1 sm:gap-1.5">
        <Icon name="material-symbols:schedule-outline-rounded" class="text-base sm:text-lg opacity-60" />
        <span>{remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount, currentLang)}</span>
      </div>
      <div class="ml-auto hidden sm:block">
        <span class="inline-flex items-center gap-1 text-xs sm:text-sm font-medium text-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all duration-300 -translate-x-2 group-hover:translate-x-0">
          {i18n(I18nKey.more, currentLang)}
          <Icon name="material-symbols:arrow-forward-rounded" class="text-lg" />
        </span>
      </div>
    </div>
  </div>
</article>
