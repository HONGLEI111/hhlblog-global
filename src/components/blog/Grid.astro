---
import { Icon } from 'astro-icon/components';

import type { Post } from '~/types';
import Image from '~/components/common/Image.astro';
import { getFormattedDate } from '~/utils/utils';

const fallbackCovers = [
  'https://img.hehonglei.cn/file/1776633499508_128688708_p0.jpg',
  'https://img.hehonglei.cn/file/1776633500887_137725199_p0.jpg',
  'https://img.hehonglei.cn/file/1776633488500_133054821_p0.jpg',
  'https://img.hehonglei.cn/file/1776633479084_121354629_p0.jpg',
];

export interface Props {
  posts?: Post[];
}

const visibleCount = 4;
---

{
  Astro.props.posts && Astro.props.posts.length > 0 && (
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {Astro.props.posts.map((post, index) => (
        <a href={post.permalink} class="group intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div class="relative aspect-[4/3] mb-4 rounded-md overflow-hidden bg-gray-200">
            <Image
              src={post.image || fallbackCovers[index % fallbackCovers.length]}
              alt={post.title || ''}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              layout="cover"
              width={400}
              height={300}
              loading={index < visibleCount ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </div>
          <div class="text-xs text-muted mb-1">
            {post.publishDate && <time datetime={post.publishDate.toISOString()}>{getFormattedDate(post.publishDate)}</time>}
          </div>
          <h3 class="font-semibold text-lg group-hover:text-primary transition-colors">{post.title}</h3>
          {post.excerpt && <p class="mt-2 text-sm text-muted line-clamp-2">{post.excerpt}</p>}
        </a>
      ))}
    </div>
  )
}
