---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import {
	getCategoryList,
	getReadCategoryList,
	getTechnologyCategoryList,
} from "../../utils/content-utils";
import ButtonLink from "../controls/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

type Collection = "posts" | "read" | "technology";

interface Props {
	class?: string;
	style?: string;
	collection?: Collection;
}
const className = Astro.props.class;
const style = Astro.props.style;
const collection = Astro.props.collection ?? "posts";

const categories = await getCategories(collection);

function getCategories(collection: Collection) {
	switch (collection) {
		case "read":
			return getReadCategoryList();
		case "technology":
			return getTechnologyCategoryList();
		default:
			return getCategoryList();
	}
}

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

const isCollapsed = categories.length >= COLLAPSE_THRESHOLD;
---

<WidgetLayout name={i18n(I18nKey.categories)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
    {categories.map((c) =>
        <ButtonLink
            url={c.url}
            badge={String(c.count)}
            label={`View all posts in the ${c.name.trim()} category`}
        >
            {c.name.trim()}
        </ButtonLink>
    )}
</WidgetLayout>