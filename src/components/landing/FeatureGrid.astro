---
import { Icon } from "astro-icon/components";

interface Feature {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<div class="px-4 py-12 md:py-16 max-w-6xl mx-auto">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f, i) => (
      <div
        class="card-base rounded-2xl p-6 text-center onload-animation group hover:-translate-y-1 transition-all duration-300"
        style={`animation-delay: ${i * 100}ms`}
      >
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-[var(--primary)]/10 flex items-center justify-center">
          <Icon name={f.icon} class="text-2xl text-[var(--primary)]" />
        </div>
        <h3 class="font-bold text-lg text-90 mb-2">{f.title}</h3>
        <p class="text-sm text-75 leading-relaxed">{f.description}</p>
      </div>
    ))}
  </div>
</div>
