---
import { Icon } from "astro-icon/components";

interface TechItem {
  name: string;
  icon: string;
}

export interface Props {
  items: TechItem[];
}

const { items } = Astro.props;
---

<div class="px-4 py-12 md:py-16 max-w-4xl mx-auto text-center">
  <div class="flex flex-wrap justify-center gap-4 md:gap-6">
    {items.map((item, i) => (
      <div
        class="onload-animation flex flex-col items-center gap-2 p-4 rounded-xl hover:bg-[var(--primary)]/5 transition-colors"
        style={`animation-delay: ${i * 80}ms`}
      >
        <Icon name={item.icon} class="text-3xl md:text-4xl text-75" />
        <span class="text-xs text-50 font-medium">{item.name}</span>
      </div>
    ))}
  </div>
</div>
