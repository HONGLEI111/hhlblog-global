---
import { Icon } from "astro-icon/components";

export interface Props {
  greeting: string;
  title: string;
  description: string;
  github?: string;
}

const { greeting, title, description, github } = Astro.props;
---

<div class="text-center px-4 py-12 md:py-20">
  <h2 class="text-lg md:text-xl font-medium text-[var(--primary)] mb-3 onload-animation">
    {greeting}
  </h2>
  <h1 class="text-3xl md:text-5xl font-extrabold text-90 mb-6 onload-animation leading-tight">
    {title}
  </h1>
  <p class="max-w-2xl mx-auto text-lg text-75 mb-8 onload-animation leading-relaxed">
    {description}
  </p>
  {github && (
    <a
      href={github}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 btn-card rounded-xl px-6 py-3 font-bold text-white bg-[var(--primary)] hover:opacity-90 transition onload-animation active:scale-95"
    >
      <Icon name="fa6-brands:github" class="text-xl" />
      View on GitHub
    </a>
  )}
</div>
