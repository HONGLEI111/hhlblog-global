---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ImageWrapper from '../misc/ImageWrapper.astro';
import type { Widget } from '~/types';

export interface Props extends Widget {
  avatar: string;
  name: string;
  role: string;
  company: string;
  bio: string;
  location: string;
  tags: string[];
  socialLinks: { name: string; icon: string; url: string }[];
}

const {
  avatar,
  name,
  role,
  company,
  bio,
  location,
  tags = [],
  socialLinks = [],
  id,
  isDark = false,
  classes = {},
  bg,
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={classes?.container as string} bg={bg}>
  <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12 lg:gap-16">
    <!-- Avatar -->
    <div class="shrink-0 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="relative w-40 h-40 md:w-52 md:h-52 lg:w-64 lg:h-64 rounded-2xl overflow-hidden ring-4 ring-[oklch(0.82_0.10_var(--hue))] shadow-xl">
        <ImageWrapper
          src={avatar}
          alt={`${name}'s avatar`}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Info -->
    <div class="flex-1 text-center md:text-left intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight font-heading text-heading mb-2">
        {name}
      </h1>
      <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">
          <Icon name="tabler:briefcase" class="w-4 h-4" />
          {role}
        </span>
        <span class="text-muted text-sm">@</span>
        <span class="text-sm font-medium text-heading">{company}</span>
      </div>
      {
        location && (
          <div class="flex items-center justify-center md:justify-start gap-1.5 text-muted text-sm mb-4">
            <Icon name="tabler:map-pin" class="w-4 h-4" />
            {location}
          </div>
        )
      }
      <p class="text-lg text-muted leading-relaxed mb-5 max-w-xl">
        {bio}
      </p>

      <!-- Tags -->
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-5">
            {tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-muted border border-gray-200 dark:border-gray-700">
                {tag}
              </span>
            ))}
          </div>
        )
      }

      <!-- Social Links -->
      {
        socialLinks.length > 0 && (
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.name}
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-muted hover:text-primary hover:bg-primary/10 dark:hover:bg-primary/10 transition-colors text-sm font-medium"
              >
                <Icon name={link.icon} class="w-5 h-5" />
                {link.name}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</WidgetWrapper>
