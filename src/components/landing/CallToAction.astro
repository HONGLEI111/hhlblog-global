---
import { Icon } from "astro-icon/components";

export interface Props {
  title: string;
  description: string;
  email?: string;
}

const { title, description, email } = Astro.props;
---

<div class="px-4 py-12 md:py-20 text-center">
  <div class="max-w-2xl mx-auto card-base rounded-2xl p-8 md:p-12 bg-[var(--primary)]/5">
    <h2 class="text-2xl md:text-3xl font-extrabold text-90 mb-4 onload-animation">
      {title}
    </h2>
    <p class="text-75 mb-8 onload-animation leading-relaxed">
      {description}
    </p>
    {email && (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 btn-card rounded-xl px-6 py-3 font-bold text-white bg-[var(--primary)] hover:opacity-90 transition onload-animation active:scale-95"
      >
        <Icon name="material-symbols:mail-outline-rounded" class="text-xl" />
        {email}
      </a>
    )}
  </div>
</div>
